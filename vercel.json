{
  "version": 2,
  "buildCommand": "node build-web.js",
  "outputDirectory": ".",
  "framework": null,
  "functions": {
    "api/content.js": {
      "maxDuration": 30,
      "memory": 1024
    },
    "api/export-pptx.js": {
      "maxDuration": 60
    }
  },
  "rewrites": [
    { "source": "/api/(.*)", "destination": "/api/$1" }
  ]
}
